# Normalize line endings across platforms:
# store text as LF in the repository
* text=auto eol=lf

# --- Text files (explicit, optional but helpful) ---
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.csv  text eol=lf

# SVG is text
*.svg  text eol=lf

# --- Images (binary, do not touch) ---
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.avif binary
*.ico  binary

# --- Fonts (binary) ---
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# --- Audio / Video (binary) ---
*.mp3  binary
*.wav  binary
*.ogg  binary
*.mp4  binary
*.webm binary
*.mov  binary

# --- Archives (binary) ---
*.zip binary
*.7z  binary
*.gz  binary
*.tar binary